{
  "expo": {
    "name": "SMARTBIOGAS",
    "slug": "SMARTBIOGAS",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/Group 120.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#253900",
          "image": "./assets/Group 120.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ]
    ],

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Group 120.png",
        "backgroundColor": "#253900"
      },
      "package": "com.anonymous.MobileAppBiogas"
    },
    "extra": {
      "eas": {
        "projectId": "06ed604c-7f5a-464c-93af-29ecd60f7aab"
      }
    }
  }
}